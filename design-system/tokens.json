{
  "$meta": {
    "name": "SlayCRM design tokens",
    "version": "0.5.0",
    "updated": "2026-07-09",
    "sources": {
      "figma": "Figma 'Miscellaneous-Design', frame 'Desktop - 10' (node 3443:2659) — the new visual direction",
      "live": "src/styles.css :root in wbern/crm — the shipped app, canonical for status/feedback tones + scales",
      "crm": "src/lib/crm.ts — StatusTone system + per-domain status maps"
    },
    "provenance": "Every value carries an origin: figma | live | reconciled. 'reconciled' = the two sources disagreed and a single value was chosen.",
    "decisions": {
      "typeface": "Geist (single family). Inter in the sketch was drift.",
      "brand": "#e26a00 (orange). Deliberately splits brand from danger — the live app uses one vermilion for BOTH accent and danger.",
      "danger": "#dc2626 (clean red). Vermilion #f5362a dropped entirely so danger never reads as an orange sibling.",
      "radius-default": "8 (control) for inputs/cards. Buttons are pill (--radius-button) per the Figma direction — primary/secondary/danger all fully rounded so they match side by side.",
      "button": "Pill radius, 10px vertical padding, 8px icon gap. Horizontal padding depends on icon: no icon = symmetric 20/20; with icon = 16px icon side / 8px gap / 24px text side (matches the Figma Button node exactly). 16/20/24 = space-4/5/6. Primary = orange solid + drop-shadow (pop) + inset highlight. Secondary = white bg, brand text, light border, no shadow. Danger = red solid, no shadow. Ghost = brand text, no border. All share the pill.",
      "font-floor": "14px. The live app floors at 12px (--text-xs); that is treated as a defect to fix, not a token to copy.",
      "neutrals": "Simplified to 3 backgrounds + 1 line + 3 text greys. The old 8e8e8e/999/a1a1aa mid-grey cluster merged to one faint #999999. Dedicated dark grounds (#1a1a20/#0e0e12) dropped — dark surfaces reuse ink #111. blue-50 selection tint removed."
    },
    "open": "Henrik is still adding Figma views. New components (nav, tables, drawers, forms) may introduce or confirm tokens. This file is additive — extend, do not rewrite."
  },

  "primitive": {
    "color": {
      "white":   { "value": "#ffffff", "src": "figma|live", "note": "bg 1 — cards, surfaces" },
      "ground":  { "value": "#f5f5f3", "src": "figma",      "note": "bg 2 — page ground (off-white)" },
      "sunken":  { "value": "#f9f9fb", "src": "figma|live", "note": "bg 3 — inset / sunken panels" },
      "line":    { "value": "#e5e5e5", "src": "reconciled", "note": "the one hairline / border (figma #e5e5e5 vs live #e7e7ea)" },
      "ink":     { "value": "#111111", "src": "figma|live", "note": "text — primary" },
      "muted":   { "value": "#666666", "src": "figma|live", "note": "text — secondary / labels" },
      "faint":   { "value": "#999999", "src": "reconciled", "note": "text — placeholder / disabled (merges old 8e8e8e/999/a1a1aa)" },

      "orange-500":   { "value": "#e26a00", "src": "figma", "note": "brand / CTA" },
      "orange-400":   { "value": "#f47300", "src": "figma", "note": "brand hover" },

      "green-600":    { "value": "#16a34a", "src": "live", "note": "success solid" },
      "green-100":    { "value": "#dcfce7", "src": "live", "note": "success tint" },
      "blue-600":     { "value": "#2563eb", "src": "figma|live", "note": "info solid" },
      "blue-100":     { "value": "#eff6ff", "src": "figma|live", "note": "info tint (badges)" },
      "amber-600":    { "value": "#d97706", "src": "live", "note": "warning solid" },
      "amber-100":    { "value": "#fef3c7", "src": "live", "note": "warning tint" },
      "red-600":      { "value": "#dc2626", "src": "reconciled", "note": "danger solid — clean red, replaces live vermilion #f5362a" },
      "red-100":      { "value": "#fee2e2", "src": "reconciled", "note": "danger tint" },

      "overlay-hover":{ "value": "rgba(0,0,0,0.04)", "src": "live", "note": "row / ghost hover bg" }
