    "feedback": {
      "$note": "solid = identitet (knappfyllning, ramar, asterisk, badge-text i ljust), temaoberoende. tint = chip-bakgrund, fg = badge-text; båda temaberoende och trimmas mot mörk yta (se semantic.theme). fg finns för att badge-texten måste ljusas i mörkt utan att röra solid, som också fyller knappar.",
      "success": { "solid": "{primitive.color.green-600}", "tint": "{primitive.color.green-100}", "fg": "{primitive.color.green-600}" },
