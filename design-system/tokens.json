        "tone-success-tint":"{primitive.color.green-100}", "tone-success-fg":"{primitive.color.green-600}",
        "tone-info-tint":"{primitive.color.blue-100}",     "tone-info-fg":"{primitive.color.blue-600}",
        "tone-warning-tint":"{primitive.color.amber-100}", "tone-warning-fg":"{primitive.color.amber-600}",
        "tone-danger-tint":"{primitive.color.red-100}",    "tone-danger-fg":"{primitive.color.red-600}",
        "tone-neutral-tint":"{primitive.color.ground}",    "tone-neutral-fg":"{primitive.color.muted}"
      }
    }
  },

  "statusMap": {
