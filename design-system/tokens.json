      "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
      "size":   { "sm": "14px", "md": "16px", "lg": "20px", "xl": "24px" },
      "lineHeight": { "sm": "18px", "md": "21px", "lg": "24px", "xl": "30px" }
    },

    "space": {
      "1": "4px", "2": "8px", "3": "12px", "4": "16px",
      "5": "20px", "6": "24px", "8": "32px", "10": "40px"
    },

    "radius": {
      "xs":   "2px",
      "sm":   "4px",
